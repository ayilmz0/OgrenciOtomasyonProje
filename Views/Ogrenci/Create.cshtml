@model OgrenciOtomasyonWeb.Models.Ogrenci

@{
    ViewData["Title"] = "Öğrenci Ekle";
}

<h2>Yeni Öğrenci Ekle</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Ad">Ad</label>
        <input asp-for="Ad" class="form-control" type="text" />
        <span asp-validation-for="Ad" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Soyad">Soyad</label>
        <input asp-for="Soyad" class="form-control" />
        <span asp-validation-for="Soyad" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="TcNo">Tc No</label>
        <input asp-for="TcNo" type="number" class="form-control" />
        <span asp-validation-for="TcNo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Email" class="form-check-label">Email</label>
        <input asp-for="Email" class="form-control" type="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="TelefonNo" class="form-check-label">Telefon No</label>
        <input asp-for="TelefonNo" class="form-control" type="tel" />
        <span asp-validation-for="TelefonNo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="OgrenciNo" class="form-check-label">Ögrenci No</label>
        <input asp-for="OgrenciNo" class="form-control" type="number" />
        <span asp-validation-for="OgrenciNo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Bolumu" class="form-check-label">Bölümü</label>
        <input asp-for="Bolumu" class="form-control" />
        <span asp-validation-for="Bolumu" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Sinif" class="form-check-label">Sınıf</label>
        <input asp-for="Sinif" class="form-control" type="number" />
        <span asp-validation-for="Sinif" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DogumTarihi" class="form-check-label">Doğum Tarihi</label>
        <input asp-for="DogumTarihi" class="form-control" type="date" />
        <span asp-validation-for="DogumTarihi" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="KayitTarihi" class="form-check-label">Kayıt Tarihi</label>
        <input asp-for="KayitTarihi" class="form-control" type="date" />
        <span asp-validation-for="KayitTarihi" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Durum"></label>
        <select asp-for="Durum" class="form-control" asp-items="Html.GetEnumSelectList<Durum>()"></select>
        <span asp-validation-for="Durum" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-3">Kaydet</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Geri Dön</a>
</form>
