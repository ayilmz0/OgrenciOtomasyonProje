@model IEnumerable<OgrenciOtomasyonWeb.Models.OgretimUyesi>
@{
    ViewData["Title"] = "Öğretim Üyesi";
}

@if (ViewBag.Hata != null)
{
    <div class="alert alert-danger">
        @ViewBag.Hata
    </div>
}

<h2>Öğretim Üyesi Listesi</h2>

<a asp-action="Create" class="btn btn-primary mb-3 float-end">Yeni Öğretim Üyesi Ekle</a>

<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="Ad" class="form-control" placeholder="Öğretim üyesi adı giriniz" value="@ViewBag.Ad" />
        <button type="submit" class="btn btn-primary">Filtrele</button>
    </div>
</form>

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Ad</th>
                <th>Soyad</th>
                <th>Email</th>
                <th>Ünvan</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ogretimUyesi in Model)
            {
                <tr>
                    <td>@ogretimUyesi.Ad</td>
                    <td>@ogretimUyesi.Soyad</td>
                    <td>@ogretimUyesi.Email</td>
                    <td>@ogretimUyesi.Unvan</td>
                    <td>@(ogretimUyesi.Durum ? "Aktif" : "Pasif")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@ogretimUyesi.OgretimUyesiId" class="btn btn-sm btn-warning">Düzenle</a>
                        <a asp-action="Delete" asp-route-id="@ogretimUyesi.OgretimUyesiId" class="btn btn-sm btn-danger">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
    <style>
        h2 {
            float: left;
        }
    </style>
