@model OgrenciOtomasyonWeb.Models.OgretimUyesi
@{
    ViewData["Title"] = "Öğretim Üyesi Sil";
}

<h2>Öğretim Üyesi Sil</h2>

<h4>Silmek istediğinize emin misiniz?</h4>

<div><strong>Ad:</strong> @Model.Ad</div>
<div><strong>Soyad:</strong> @Model.Soyad</div>
<div><strong>Email:</strong> @Model.Email</div>
<div><strong>Unvan:</strong> @Model.Unvan</div>
<div><strong>Durum:</strong> @(Model.Durum ? "Aktif" : "Pasif")</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="OgretimUyesiId" />
    <button type="submit" class="btn btn-danger mt-3">Sil</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">İptal</a>
</form>
