@model OgrenciOtomasyonWeb.Models.Dersler
@{
    ViewData["Title"] = "Ders Düzenle";
}

<h2>Ders Düzenle</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="DersId" />
    <div class="form-group">
        <label asp-for="DersAdi">Ders Adı</label>
        <input asp-for="DersAdi" class="form-control" />
        <span asp-validation-for="DersAdi" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DersKodu">Ders Kodu</label>
        <input asp-for="DersKodu" class="form-control" />
        <span asp-validation-for="DersKodu" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Kredi"></label>
        <input asp-for="Kredi" type="number" class="form-control" />
        <span asp-validation-for="Kredi" class="text-danger"></span>
    </div>
    <div class="form-check">
        <input asp-for="Durum" class="form-check-input" type="checkbox" />
        <label asp-for="Durum" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary mt-3">Güncelle</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Geri Dön</a>
</form>
